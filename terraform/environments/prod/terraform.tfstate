      "module": "module.infrastructure",
      "mode": "data",
      "type": "cloudinit_config",
      "name": "vm_init",
      "provider": "provider[\"registry.terraform.io/hashicorp/cloudinit\"]",
      "instances": [
        {
          "schema_version": 0,
          "attributes": {
            "base64_encode": true,
            "boundary": "MIMEBOUNDARY",
            "gzip": true,
            "id": "3854885990",
            "part": [
              {
                "content": "#cloud-config\n\n# Update packages on first boot\npackage_update: true\npackage_upgrade: true\n\n# Install required packages\npackages:\n  - curl\n  - wget\n  - git\n  - ufw\n  - fail2ban\n  - unattended-upgrades\n  - apt-transport-https\n  - ca-certificates\n  - software-properties-common\n  - gnupg\n  - lsb-release\n\n# Configure firewall (UFW)\nruncmd:\n  # Install Docker\n  - curl -fsSL https://get.docker.com -o get-docker.sh\n  - sh get-docker.sh\n  - usermod -aG docker azureuser\n  \n  # Install Docker Compose\n  - curl -L \"https://github.com/docker/compose/releases/latest/download/docker-compose-$(uname -s)-$(uname -m)\" -o /usr/local/bin/docker-compose\n  - chmod +x /usr/local/bin/docker-compose\n  \n  # Install Azure CLI (for storage access)\n  - curl -sL https://aka.ms/InstallAzureCLIDeb | bash\n  \n  # Configure UFW firewall\n  - ufw default deny incoming\n  - ufw default allow outgoing\n  - ufw allow 22/tcp\n  - ufw allow 80/tcp\n  - ufw allow 443/tcp\n  - ufw --force enable\n  \n  # Enable fail2ban\n  - systemctl enable fail2ban\n  - systemctl start fail2ban\n  \n  # Create application directory\n  - mkdir -p /opt/task-manager\n  - chown azureuser:azureuser /opt/task-manager\n  \n  # Enable automatic security updates\n  - dpkg-reconfigure --priority=low unattended-upgrades\n\n# Reboot to apply all changes\npower_state:\n  mode: reboot\n  message: \"Rebooting after initial setup\"\n  condition: true",
                "content_type": "text/cloud-config",
                "filename": null,
                "merge_type": null
              }
            ],
            "rendered": ""
          },
          "sensitive_attributes": []
        }
      ]
    },
